{% comment %}
  FAQ Accordion Section
  Reusable across product, homepage, and collection pages.
  Uses native <details> element — no JS required.

  Parameters:
    blinds (boolean) — include blinds-specific FAQ items after the general ones

  Usage:
    {% render 'component.faq' %}
    {% render 'component.faq', blinds: true %}
{% endcomment %}

<div class="bg-surface-white">
    <div class="container mx-auto rz-page-gutter pt-16 pb-24 lg:pt-24 lg:pb-32 text-content">
        <h2 class="rz-h1 text-center">{{ 'components.faq.title' | t }}</h2>
        <div class="mt-16 lg:mt-20 max-w-3xl mx-auto">
            {% for i in (1..10) %}
                {% assign q_key = 'components.faq.items.' | append: i | append: '.question' %}
                {% assign a_key = 'components.faq.items.' | append: i | append: '.answer' %}
                {% assign question = q_key | t %}
                {% assign answer = a_key | t %}
                {% unless question contains 'translation missing' %}
                    <details class="group border-b border-content-tertiary">
                        <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
                            <span class="rz-h4 pr-4">{{ question }}</span>
                            <span class="shrink-0 text-content-secondary transition-transform group-open:rotate-45">
                                {% render 'icon-plus', class: 'h-4 w-4 text-content' %}
                            </span>
                        </summary>
                        <div class="pb-6 text-content-secondary leading-relaxed">
                            {{ answer }}
                        </div>
                    </details>
                {% endunless %}
            {% endfor %}
            {% if blinds %}
                {% for i in (1..10) %}
                    {% assign q_key = 'components.faq.blinds.' | append: i | append: '.question' %}
                    {% assign a_key = 'components.faq.blinds.' | append: i | append: '.answer' %}
                    {% assign question = q_key | t %}
                    {% assign answer = a_key | t %}
                    {% unless question contains 'translation missing' %}
                        <details class="group border-b border-content-tertiary">
                            <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
                                <span class="rz-h4 pr-4">{{ question }}</span>
                                <span class="shrink-0 text-content-secondary transition-transform group-open:rotate-45">
                                    {% render 'icon-plus', class: 'h-4 w-4 text-content' %}
                                </span>
                            </summary>
                            <div class="pb-6 text-content-secondary leading-relaxed">
                                {{ answer }}
                            </div>
                        </details>
                    {% endunless %}
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
