{% comment %}
    Collection page — simple flat grid.
    Use collection.v2.liquid for tag-based grouping.
{% endcomment %}

{% comment %} ── Page header ── {% endcomment %}
<div class="bg-surface-white">
    <div class="container mx-auto rz-page-gutter pt-16 pb-12 lg:pt-24 lg:pb-16 text-center">
        <h1 class="rz-h1">{{ collection.title }}</h1>
        {% if collection.description != blank %}
            <p class="mt-4 text-content-secondary text-lg leading-relaxed max-w-2xl mx-auto">{{ collection.description | strip_html }}</p>
        {% endif %}
    </div>
</div>

{% comment %} ── Product grid ── {% endcomment %}
<div class="bg-surface-100">
    <div class="container mx-auto rz-page-gutter pt-8 pb-16 lg:pb-24">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-4 gap-y-8">
            {% for product in collection.products %}
                {% render 'product-card', product: product %}
            {% endfor %}
        </div>
    </div>
</div>

{% render 'component.faq' %}
