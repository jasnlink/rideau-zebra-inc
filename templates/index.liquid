<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ request.origin | json }}
    }
</script>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": {{ shop.name | json }},
        "url": {{ request.origin | json }},
        "image": {{ 'logo-main.png' | asset_url | prepend: "https:" | json }},
        "telephone": "(450) 912-9327",
        "email": "contact@rideauzebra.ca",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "1915 rue Poupart",
            "addressLocality": "Montréal",
            "addressRegion": "QC",
            "postalCode": "H2K3H1",
            "addressCountry": "CA"
        },
        "priceRange": "$$"
    }
</script>
{% comment %} ── 1. Title + Mentioned-by bar + Products ── {% endcomment %}
{% assign language = localization.language.iso_code %}
<div class="relative overflow-hidden">
    <video autoplay loop playsinline muted preload class="absolute inset-0 h-full w-full object-cover">
        <source src="{{ 'page-index-hero-main-v2-x720.mp4' | asset_url }}" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-content/60"></div>
    <div class="relative container mx-auto pt-16 lg:pt-24 pb-16 lg:pb-24 text-center text-content-inverse">
        <div class="rz-h1 text-content-inverse">{{ 'templates.homepage.showcase.title' | t }}</div>
    </div>
</div>

<div class="bg-surface-100">
    {% comment %} Compact "mentioned by" logo bar {% endcomment %}
    <div class="container mx-auto pt-8 pb-8">
        <div class="rz-caption text-center uppercase tracking-wide font-medium text-content-secondary">{{ 'templates.homepage.partners.title' | t }}</div>
        {% comment %} Desktop: centered grid — Mobile: horizontal scroll {% endcomment %}
        <div class="mt-3 flex gap-6 lg:gap-4 items-center lg:justify-center overflow-x-auto lg:overflow-x-visible scrollbar-hide px-4 lg:px-0 snap-x snap-mandatory" data-rz-partner-scroll>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {% if language == 'fr' %}
                    {% assign partner_url = 'https://www.fadoq.ca/ile-de-montreal/rabais/habitation/rideau-zebra' %}
                {% else %}
                    {% assign partner_url = 'https://www.fadoq.ca/en/ile-de-montreal/discounts/housing/827952-2' %}
                {% endif %}
                {%- assign image = 'partner-logo-fadoq.svg' -%}
                <a href="{{ partner_url }}" class="block" target="_blank">
                    <img src="{{ image | asset_url }}" alt="FADOQ" height="40" width="120" loading="eager" class="h-8 lg:h-10 w-auto object-contain" />
                </a>
            </div>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {%- assign image = 'partner-logo-fm1033.png' -%}
                <img src="{{ image | asset_img_url: '240x' }}" alt="FM103.3" height="40" width="120" loading="eager" class="h-8 lg:h-10 w-auto object-contain" />
            </div>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {%- assign image = 'partner-logo-courrier-v2.png' -%}
                <a href="https://www.lecourrierdusud.ca/les-stores-alternes-un-equilibre-parfait-entre-style-et-fonctionnalite" class="block" target="_blank">
                    <img src="{{ image | asset_img_url: '240x' }}" alt="Courrier du Sud" height="40" width="120" loading="eager" class="h-10 lg:h-12 w-auto object-contain" />
                </a>
            </div>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {%- assign image = 'partner-logo-gravite-media.png' -%}
                <img src="{{ image | asset_img_url: '240x' }}" alt="Gravité Média" height="40" width="120" loading="eager" class="h-8 lg:h-10 w-auto object-contain" />
            </div>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {%- assign image = 'partner-logo-ma-vie-ma-region.png' -%}
                <img src="{{ image | asset_img_url: '240x' }}" alt="Ma Vie Ma Région" height="40" width="120" loading="eager" class="h-8 lg:h-10 w-auto object-contain" />
            </div>
            <div class="flex-shrink-0 snap-center flex items-center justify-center">
                {%- assign image = 'partner-logo-walmart.png' -%}
                <img src="{{ image | asset_img_url: '240x' }}" alt="Walmart" height="40" width="120" loading="eager" class="h-8 lg:h-10 w-auto object-contain" />
            </div>
        </div>
    </div>

    {%- assign homepage_collection = collections['frontpage'] -%}

    {% comment %} ── Product type groups ── {% endcomment %}
    {% assign product_types = 'zebra-blinds,curtains,opaque-blinds' | split: ',' %}

    {% for pt in product_types %}
        {% assign pt_tag = 'product-type:' | append: pt %}
        {% assign pt_count = 0 %}
        {% for product in homepage_collection.products %}
            {% for tag in product.tags %}
                {% if tag == pt_tag %}
                    {% assign pt_count = pt_count | plus: 1 %}
                    {% break %}
                {% endif %}
            {% endfor %}
        {% endfor %}

        {% if pt_count > 0 %}
            {% assign pt_title_key = 'collections.groups.product_type.' | append: pt | append: '.title' %}
            {% assign pt_desc_key = 'collections.groups.product_type.' | append: pt | append: '.description' %}

            <div class="container mx-auto rz-page-gutter pt-12 pb-16 lg:pt-16 lg:pb-20">
                <div class="border-t border-content-tertiary pt-8">
                    <span class="rz-overline text-content-secondary">{{ pt_title_key | t }}</span>
                    <p class="mt-2 text-content-secondary leading-relaxed max-w-xl">{{ pt_desc_key | t }}</p>
                </div>

                <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-x-4 gap-y-8">
                    {% for product in homepage_collection.products %}
                        {% assign has_pt = false %}
                        {% for tag in product.tags %}
                            {% if tag == pt_tag %}
                                {% assign has_pt = true %}
                                {% break %}
                            {% endif %}
                        {% endfor %}
                        {% if has_pt %}
                            {% render 'product-card', product: product %}
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    {% endfor %}

    {% comment %} ── Uncategorized products ── {% endcomment %}
    {% assign uncategorized_count = 0 %}
    {% for product in homepage_collection.products %}
        {% assign has_known_type = false %}
        {% for tag in product.tags %}
            {% if tag == 'product-type:zebra-blinds' or tag == 'product-type:curtains' or tag == 'product-type:opaque-blinds' %}
                {% assign has_known_type = true %}
                {% break %}
            {% endif %}
        {% endfor %}
        {% unless has_known_type %}
            {% assign uncategorized_count = uncategorized_count | plus: 1 %}
        {% endunless %}
    {% endfor %}

    {% if uncategorized_count > 0 %}
        <div class="container mx-auto rz-page-gutter pt-8 pb-16 lg:pb-24">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-4 gap-y-8">
                {% for product in homepage_collection.products %}
                    {% assign has_known_type = false %}
                    {% for tag in product.tags %}
                        {% if tag == 'product-type:zebra-blinds' or tag == 'product-type:curtains' or tag == 'product-type:opaque-blinds' %}
                            {% assign has_known_type = true %}
                            {% break %}
                        {% endif %}
                    {% endfor %}
                    {% unless has_known_type %}
                        {% render 'product-card', product: product %}
                    {% endunless %}
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

{% comment %} ── 2. Payments Accepted band ── {% endcomment %}
<div class="bg-brand-700">
    <div class="mx-auto py-6 lg:py-6">
        <div class="flex flex-col gap-y-2 sm:gap-y-6 lg:flex-row items-center justify-center gap-x-4">
            <span class="rz-overline text-content-inverse">{{ 'templates.homepage.payments_accepted.title' | t }}</span>
            <div class="inline-flex justify-center gap-y-2 gap-x-2 flex-wrap">
                {% for type in shop.enabled_payment_types -%}
                    {{ type | payment_type_svg_tag: class: 'h-8 w-auto' }}
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{% comment %} ── 3. How to order — 3-step process ── {% endcomment %}
<div class="bg-surface-100">
    <div class="container mx-auto pt-16 pb-24 lg:pt-24 lg:pb-32 rz-page-gutter text-content">
        <h2 class="rz-h1 w-full text-center">{{ 'templates.homepage.how_to_order.title' | t }}</h2>
        <div class="mt-20 lg:mt-24 grid grid-cols-1 sm:grid-cols-3 gap-12 lg:gap-16">
            <div class="border-t border-content-tertiary pt-8">
                <div class="rz-overline text-content-secondary">{{ 'templates.homepage.how_to_order.step_label' | t: step: 1 }}</div>
                <div class="mt-3 rz-h3">{{ 'templates.homepage.how_to_order.step_1.title' | t }}</div>
                <p class="mt-4 text-content-secondary leading-relaxed">{{ 'templates.homepage.how_to_order.step_1.description' | t }}</p>
            </div>
            <div class="border-t border-content-tertiary pt-8">
                <div class="rz-overline text-content-secondary">{{ 'templates.homepage.how_to_order.step_label' | t: step: 2 }}</div>
                <div class="mt-3 rz-h3">{{ 'templates.homepage.how_to_order.step_2.title' | t }}</div>
                <p class="mt-4 text-content-secondary leading-relaxed">{{ 'templates.homepage.how_to_order.step_2.description' | t }}</p>
            </div>
            <div class="border-t border-content-tertiary pt-8">
                <div class="rz-overline text-content-secondary">{{ 'templates.homepage.how_to_order.step_label' | t: step: 3 }}</div>
                <div class="mt-3 rz-h3">{{ 'templates.homepage.how_to_order.step_3.title' | t }}</div>
                <p class="mt-4 text-content-secondary leading-relaxed">{{ 'templates.homepage.how_to_order.step_3.description' | t }}</p>
            </div>
        </div>
    </div>
</div>

{% comment %} ── 4. Featured project ── {% endcomment %}
{% assign featured_article = articles['news/custom-zebra-blinds-installations-rideau-zebra-elevates-fm-103-3s-studios'] %}
<div class="bg-surface-white">
    <div class="container mx-auto rz-page-gutter py-16 lg:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <div class="overflow-hidden rounded-md">
                <img
                    src="{{ featured_article.image | image_url: width: 900 }}"
                    srcset="{{ featured_article.image | image_url: width: 600 }} 600w, {{ featured_article.image | image_url: width: 900 }} 900w, {{ featured_article.image | image_url: width: 1200 }} 1200w"
                    sizes="(min-width: 1024px) 50vw, 100vw"
                    alt="{{ featured_article.title }}"
                    width="900" height="600"
                    loading="lazy"
                    class="w-full h-auto object-cover"
                />
            </div>
            <div>
                <span class="rz-overline text-content-secondary">{{ 'templates.homepage.featured_project.overline' | t }}</span>
                <h2 class="mt-4 rz-h2">{{ 'templates.homepage.featured_project.title' | t }}</h2>
                <p class="mt-6 text-content-secondary leading-relaxed">{{ 'templates.homepage.featured_project.description' | t }}</p>
                <a href="{{ featured_article.url }}" class="inline-block mt-8 rz-btn-md rz-btn-secondary" title="{{ featured_article.title }}">{{ 'templates.homepage.featured_project.cta' | t }}</a>
            </div>
        </div>
    </div>
</div>

{% comment %} ── 5. Hero video CTA ── {% endcomment %}
<div class="h-[calc(100vh_-_89px)] w-full bg-surface-100 relative">
    <video autoplay loop playsinline muted preload class="h-full w-full object-cover">
        <source src="{{ 'page-index-hero-main-v2-x720.mp4' | asset_url }}" type="video/mp4" />
    </video>
    <div class="absolute top-1/2 -translate-y-1/2 w-full text-center">
        <div class="rz-hero-title text-content-inverse">{{ 'templates.homepage.hero.title' | t }}</div>
        <a href="{{ routes['collections_url'] }}" class="block mt-12 mx-auto w-fit h-fit rz-btn-lg rz-btn-primary" title="{{ 'templates.homepage.hero.button' | t }}">{{ 'templates.homepage.hero.button' | t }}</a>
    </div>
</div>

