{% comment %}
    Collection page v2 — products grouped by type.
    Requires product-type: tags on products to group them.
    Products without tags fall into "Other Products".
{% endcomment %}

{% comment %} ── Page header ── {% endcomment %}
<div class="bg-surface-white">
    <div class="container mx-auto rz-page-gutter pt-16 pb-12 lg:pt-24 lg:pb-16 text-center">
        <h1 class="rz-h1">{{ collection.title }}</h1>
        {% if collection.description != blank %}
            <p class="mt-4 text-content-secondary text-lg leading-relaxed max-w-2xl mx-auto">{{ collection.description | strip_html }}</p>
        {% endif %}
    </div>
</div>

{% comment %} ── Product type groups ── {% endcomment %}
{% assign product_types = 'zebra-blinds,curtains,opaque-blinds' | split: ',' %}

{% for pt in product_types %}
    {% assign pt_count = 0 %}
    {% for product in collection.products %}
        {% for tag in product.tags %}
            {% if tag == 'product-type:' | append: pt %}
                {% assign pt_count = pt_count | plus: 1 %}
                {% break %}
            {% endif %}
        {% endfor %}
    {% endfor %}

    {% if pt_count > 0 %}
        {% assign pt_title_key = 'collections.groups.product_type.' | append: pt | append: '.title' %}
        {% assign pt_desc_key = 'collections.groups.product_type.' | append: pt | append: '.description' %}

        <div class="bg-surface-100">
            <div class="container mx-auto rz-page-gutter pt-16 pb-20 lg:pt-24 lg:pb-28" id="{{ pt }}">
                <div class="border-t border-content-tertiary pt-8">
                    <span class="rz-overline text-content-secondary">{{ pt_title_key | t }}</span>
                    <p class="mt-2 text-content-secondary leading-relaxed max-w-xl">{{ pt_desc_key | t }}</p>
                </div>

                <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-x-4 gap-y-8">
                    {% for product in collection.products %}
                        {% assign has_pt = false %}
                        {% for tag in product.tags %}
                            {% if tag == 'product-type:' | append: pt %}
                                {% assign has_pt = true %}
                                {% break %}
                            {% endif %}
                        {% endfor %}
                        {% if has_pt %}
                            {% render 'product-card', product: product %}
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% comment %} ── Uncategorized products ── {% endcomment %}
{% assign uncategorized_count = 0 %}
{% for product in collection.products %}
    {% assign has_known_type = false %}
    {% for tag in product.tags %}
        {% if tag == 'product-type:zebra-blinds' or tag == 'product-type:curtains' or tag == 'product-type:opaque-blinds' %}
            {% assign has_known_type = true %}
            {% break %}
        {% endif %}
    {% endfor %}
    {% unless has_known_type %}
        {% assign uncategorized_count = uncategorized_count | plus: 1 %}
    {% endunless %}
{% endfor %}

{% if uncategorized_count > 0 %}
    <div class="bg-surface-100">
        <div class="container mx-auto rz-page-gutter pt-16 pb-20 lg:pt-24 lg:pb-28">
            <div class="border-t border-content-tertiary pt-8">
                <h2 class="rz-h2">{{ 'collections.groups.other.title' | t }}</h2>
            </div>

            <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-x-4 gap-y-8">
                {% for product in collection.products %}
                    {% assign has_known_type = false %}
                    {% for tag in product.tags %}
                        {% if tag == 'product-type:zebra-blinds' or tag == 'product-type:curtains' or tag == 'product-type:opaque-blinds' %}
                            {% assign has_known_type = true %}
                            {% break %}
                        {% endif %}
                    {% endfor %}
                    {% unless has_known_type %}
                        {% render 'product-card', product: product %}
                    {% endunless %}
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}

{% render 'component.faq' %}
