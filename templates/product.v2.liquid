<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": {{ product.title | json }},
        "url": {{ request.origin | append: product.url | json }},
        "image": [
            {{ product.featured_image | image_url: width: 800 | prepend: "https:" | json }}
        ],
        "description": {{ product.description | strip_html | json }},
        {% if product.selected_or_first_available_variant.sku != blank -%}
            "sku": {{ product.selected_or_first_available_variant.sku | json }},
        {%- endif %}
        "brand": {
            "@type": "Brand",
            "name": {{ product.vendor | json }}
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": 5.0,
            "bestRating": 5,
            "worstRating": 1,
            "reviewCount": 10
        },
        "review": [
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Carl C." },
                "datePublished": "2024-03-01",
                "reviewBody": "We are happy that we decided to go with Rideau Zebra. The quality of the blinds were very good and their attention to installation was excellent. I recommend their company/products if you need blinds for your house or condo.",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Jean-Daniel P." },
                "datePublished": "2025-01-15",
                "reviewBody": "From the initial contact with Rideau Zebra to the installation, everything went smoothly, efficiently, and pleasantly. Lucie was invaluable and fully committed to our project. The result is magnificent and brings a beautiful harmony to our condo. A fantastic local company that I recommend without hesitation!",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Marie-Noël G." },
                "datePublished": "2025-02-10",
                "reviewBody": "We had a wonderful experience purchasing our home blinds from Rideau Zebra. Lucie's service was impeccable; professional and friendly; communication was quick and clear. The result is truly superb. Thank you for everything, we are delighted!",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Charlie C." },
                "datePublished": "2025-03-01",
                "reviewBody": "Excellent !",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Johanne and Paul" },
                "datePublished": "2025-01-01",
                "reviewBody": "We installed our blinds this morning, and everything is perfect. Thank you for the great service. We look forward to referring your business to our friends.",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "St\u00e9phanie" },
                "datePublished": "2025-02-01",
                "reviewBody": "The team was very helpful and patient in helping me choose the right model for my living room. I'm thrilled with my purchase and highly recommend them.",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Alexandre" },
                "datePublished": "2025-03-01",
                "reviewBody": "I recently bought zebra blinds for my home office and couldn't be happier. Thank you for your excellent customer service and expertise.",
                "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 }
            }
        ],
        "offers": [
            {%- for variant in product.variants -%}
            {
                "@type" : "Offer",
                {%- if variant.sku != blank -%}
                "sku": {{ variant.sku | json }},
                {%- endif -%}
                {%- if variant.barcode.size == 12 -%}
                "gtin12": {{ variant.barcode | json }},
                {%- endif -%}
                {%- if variant.barcode.size == 13 -%}
                "gtin13": {{ variant.barcode | json }},
                {%- endif -%}
                {%- if variant.barcode.size == 14 -%}
                "gtin14": {{ variant.barcode | json }},
                {%- endif -%}
                "availability" : "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
                "price" : {{ variant.price | divided_by: 100.00 | json }},
                "priceCurrency" : {{ cart.currency.iso_code | json }},
                "url" : {{ request.origin | append: variant.url | json }}
            }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
        ]
    }
</script>
<div data-animation-object="cart" class="fixed z-50 hidden">
    <div class="p-1 bg-brand-600 rounded-full">{% render 'icon-item', class: 'h-4 w-4 fill-content-inverse' %}</div>
</div>
<div class="container 2xl:px-0 pt-6 pb-12 mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 lg:gap-8 xl:gap-12">
        <div class="col-span-7">
            <div class="hidden lg:flex flex-col gap-2">
                {% for media in product.media %}
                    <div class="flex items-center justify-center aspect-square rounded-md">
                    {% if media.media_type == 'image' %}
                        <picture class="flex flex-grow">
                            <source srcset="{{ media | image_url: width: 1154 }}" media="(min-width:1536px)" />
                            <source srcset="{{ media | image_url: width: 1018 }}" media="(min-width:1280px)" />
                            <source srcset="{{ media | image_url: width: 868 }}" media="(min-width:1024px)" />
                            <source srcset="{{ media | image_url: width: 1152 }}" media="(min-width:768px)" />
                            <source srcset="{{ media | image_url: width: 896 }}" media="(min-width:640px)" />
                            <source srcset="{{ media | image_url: width: 768 }}" media="(min-width:0px)" />
                            <img src="{{ media | image_url: width: 768 }}" alt="{{ image.alt }}" height="200" width="200" loading="lazy" class="w-full h-full object-contain rounded-md" />
                        </picture>
                    {% elsif media.media_type == 'video' %}
                        {{ media | video_tag: image_size: '480x', playsinline: '', autoplay: true, loop: true, muted: true, class: 'w-full h-full object-cover rounded-md' }}
                    {% endif %}
                    </div>
                {% endfor %}
            </div>
            <div class="glide lg:hidden">
                <div class="glide__track" data-glide-el="track">
                    <ul class="glide__slides">
                        {% for media in product.media %}
                            <li class="glide__slide">
                                <div class="flex items-center justify-center aspect-square rounded-md">
                                    {% if media.media_type == 'image' %}
                                        <picture class="flex flex-grow">
                                            <source srcset="{{ media | image_url: width: 1154 }}" media="(min-width:1536px)" />
                                            <source srcset="{{ media | image_url: width: 1018 }}" media="(min-width:1280px)" />
                                            <source srcset="{{ media | image_url: width: 868 }}" media="(min-width:1024px)" />
                                            <source srcset="{{ media | image_url: width: 1152 }}" media="(min-width:768px)" />
                                            <source srcset="{{ media | image_url: width: 896 }}" media="(min-width:640px)" />
                                            <source srcset="{{ media | image_url: width: 768 }}" media="(min-width:0px)" />
                                            <img src="{{ media | image_url: width: 768 }}" alt="{{ image.alt }}" height="200" width="200" loading="lazy" class="w-full h-full object-contain rounded-md" />
                                        </picture>
                                    {% elsif media.media_type == 'video' %}
                                        {{ media | video_tag: image_size: '480x', playsinline: '', autoplay: true, loop: true, muted: true, class: 'w-full h-full object-cover rounded-md' }}
                                    {% endif %}
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="mt-2 grid grid-cols-6 gap-2" data-glide-el="controls">
                    {% for media in product.media %}
                        <div role="button" data-glide-dir="={{ forloop.index0 }}">
                            <div class="flex items-stretch justify-center bg-content-light aspect-square rounded-md">
                                <picture class="flex flex-grow">
                                    <img src="{{ media | image_url: width: 196 }}" alt="{{ image.alt }}" height="120" width="120" loading="lazy" class="w-full h-full object-cover rounded" />
                                </picture>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="col-span-5 text-content relative">
            <div class="sticky top-24">
                <form data-rz-product-forms="form">
                    <div class="py-4 lg:py-6 mx-auto">
                        <div class="rz-h1 mt-4">{{ product.title }}</div>
                        <a href="#reviews" class="mt-2 block w-fit">
                            {% assign review_label = 'products.reviews.review_count' | t: count: 10 %}
                            {% render 'component.star-rating',
                                rating: 5.0,
                                label: review_label,
                                size_class: 'h-4 w-4',
                                text_class: 'text-sm'
                            %}
                        </a>
                        <div class="mt-4 pt-4 rz-divider">{{ product.description | strip_html }}</div>
                        {% comment %} Check if product has a valid product type {% endcomment %}
                        {% assign has_product_type = false %}
                        {% for tag in product.tags %}
                            {% if tag contains 'product-type:' %}
                                {% assign product_type = tag | remove: 'product-type:' %}
                                {% if product_type == 'zebra-blinds' or product_type == 'curtains' or product_type == 'opaque-blinds' %}
                                    {% assign has_product_type = true %}
                                    {% break %}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                        {% comment %} Detect product operation mechanism {% endcomment %}
                        {% assign product_operation = 'cordless' %}
                        {% for tag in product.tags %}
                            {% if tag contains 'operation:' %}
                                {% assign product_operation = tag | remove: 'operation:' %}
                                {% break %}
                            {% endif %}
                        {% endfor %}
                        {% comment %} Detect product tier for specs {% endcomment %}
                        {% assign product_tier = '' %}
                        {% for tag in product.tags %}
                            {% if tag contains 'tier:' %}
                                {% assign product_tier = tag | remove: 'tier:' %}
                                {% break %}
                            {% endif %}
                        {% endfor %}
                        {% comment %} Map tier to spec tier (basic/standard → basic, premium → premium) {% endcomment %}
                        {% assign spec_tier = product_tier %}
                        {% if product_tier == 'standard' %}
                            {% assign spec_tier = 'basic' %}
                        {% endif %}
                        {% if has_product_type %}
                            {% render 'component.color-selector' %}

                            {% comment %} <label class="p-4 transition-all cursor-pointer select-none max-w-full text-clip overflow-hidden rounded-md flex gap-4 items-center bg-surface-white border border-content-light hover:bg-surface-50 has-[:checked]:bg-brand-200 has-[:checked]:border-brand-500" for="install-check">
                                <input class="hidden peer" type="checkbox" id="install-check" data-product-install-service-item-id="{{ all_products['professional-window-blind-installation-service'].first_available_variant.id }}">
                                <span class="transition-all opacity-20 peer-checked:opacity-100">{% render 'icon-success', class: 'h-6 fill-brand-500' %}</span>
                                {% assign installPrice = all_products['professional-window-blind-installation-service'].price | money_without_trailing_zeros %}
                                <span>{{ 'products.product.cordless_zebra_blinds.have_us_install' | t: installPrice: installPrice }}</span>
                            </label> {% endcomment %}

                            {% render 'component.product-forms' %}
                        {% endif %}
                        {% if product.has_only_default_variant == false %}
                            <div class="mt-6 hidden">
                                {% render 'product.section.variant-selector',
                                    type: 'dropdown',
                                    groupId: 0
                                %}
                            </div>
                        {% endif %}
                        {% if has_product_type %}
                            <div class="mt-2">
                                <label class="p-4 transition-all cursor-pointer select-none max-w-full text-clip overflow-hidden rounded-md flex gap-4 items-center bg-surface-white border border-content-light hover:bg-surface-50 has-[:checked]:bg-brand-200 has-[:checked]:border-brand-500" for="install-check">
                                    <input class="hidden peer" type="checkbox" id="install-check" data-product-install-service-item-id="{{ all_products['professional-window-blind-installation-service'].first_available_variant.id }}">
                                    <span class="transition-all opacity-20 peer-checked:opacity-100">{% render 'icon-success', class: 'h-6 fill-brand-500' %}</span>
                                    {% assign installPrice = all_products['professional-window-blind-installation-service'].price | money_without_trailing_zeros %}
                                    <span>{{ 'products.product.cordless_zebra_blinds.have_us_install' | t: installPrice: installPrice }}</span>
                                </label>
                            </div>
                        {% endif %}
                        <div class="pt-4 pb-2 flex items-center justify-between gap-8">
                            <span data-product-display-price class="text-2xl font-light shrink-0">{{ product.selected_or_first_available_variant.price | money_with_currency }}</span>
                            {% comment %} {% if product.collections contains collections['zebra-blinds'] or product.collections contains collections['motorized-cordless-zebra-blinds'] %}
                                <div class="shrink flex items-center gap-1 bg-trust-100 border border-trust-300 rounded-md px-4 py-1">
                                    <span>{% render 'icon-success', class: 'h-4 fill-trust-500' %}</span>
                                    <span class="text-xs font-medium text-trust-500">{{ 'products.product.pickup_availability.pick_up_available_montreal' | t }}</span>
                                </div>
                            {% endif %} {% endcomment %}
                            <div data-product-display-availability="true" class="hidden flex-col">
                                <span class="text-sm font-medium text-trust-400">{{ 'products.product.in_stock' | t }}</span>
                                <span class="text-sm font-medium">{{ 'products.product.free_shipping' | t }}</span>
                            </div>
                            <div data-product-display-availability="false" class="hidden flex-col">
                                <span class="text-sm font-medium text-danger">{{ 'products.product.out_of_stock' | t }}</span>
                            </div>
                        </div>
                        {% assign button_text = 'products.product.add_to_cart' | t %}
                        <div class="mt-2 hidden items-center gap-2 rounded-md bg-danger/10 px-4 py-3 text-danger"
                            data-rz-width-warning
                            data-rz-width-warning-too-small="{{ 'products.product.cordless_zebra_blinds.width_warning.too_small' | t }}"
                            data-rz-width-warning-too-large="{{ 'products.product.cordless_zebra_blinds.width_warning.too_large' | t }}">
                            {% render 'icon-error', class: 'h-5 w-5 flex-shrink-0 text-danger', fill: 'none' %}
                            <span class="text-sm font-medium" data-rz-width-warning-text></span>
                        </div>
                        <div class="mt-2 w-full" data-overlay-listen>
                            {% render 'product.component.add-cart-button',
                                button_text: button_text
                            %}
                        </div>
                        <div class="mt-3 inline-flex w-full justify-center gap-y-2 gap-x-2 flex-wrap">
                            {% for type in shop.enabled_payment_types -%}
                                {{ type | payment_type_svg_tag: class: 'h-8 w-auto' }}
                            {% endfor %}
                        </div>
                        <div class="mt-2 flex justify-center items-center">
                            <div class="w-fit rz-btn-trust flex items-center gap-x-2">{% render 'icon-secure', class: 'h-4 w-auto fill-content' %} <span>{{ 'sections.footer.ssl_encrypted' | t }}</span></div>
                        </div>
                        <div class="mt-3">
                            {% render 'component.questions-scheduler' %}
                        </div>
                        {% comment %} {% if product.collections contains collections['zebra-blinds'] or product.collections contains collections['motorized-cordless-zebra-blinds'] %}
                            <div class="mt-4 py-2 flex gap-4 justify-center items-center bg-brand-800 rounded-md px-8 border border-content-tertiary">
                                <span>{% render 'icon-fixed-rate-shipping', class: 'h-6 w-auto fill-content-inverse' %}</span>
                                <span class="font-medium text-content-inverse">{{ 'products.product.cordless_zebra_blinds.highlight_badges.0' | t | newline_to_br }}</span>
                            </div>
                            <div class="mt-2 py-1 flex gap-4 justify-center items-center bg-brand-100 rounded-md px-8 border border-brand-300">
                                <span>{% render 'icon-shipping', class: 'h-8 w-auto fill-content-secondary' %}</span>
                                <span class="font-medium text-content-secondary">{{ 'products.product.cordless_zebra_blinds.highlight_badges.1' | t | newline_to_br }}</span>
                            </div>
                        {% endif %} {% endcomment %}
                    </div>
                </form>
                {% if has_product_type %}
                    <div data-product-tab-group="0">
                        <div class="grid grid-cols-3 gap-x-4 text-center py-4 rz-divider lg:whitespace-nowrap">
                            <div role="button" data-product-tab-action="0" class="transition-all hover:font-semibold font-light">{{ 'products.product.cordless_zebra_blinds.highlights.tab_title' | t }}</div>
                            <div role="button" data-product-tab-action="1" class="transition-all hover:font-semibold font-light">{{ 'products.product.cordless_zebra_blinds.materials_care.tab_title' | t }}</div>
                            <div role="button" data-product-tab-action="2" class="transition-all hover:font-semibold font-light">{{ 'products.product.cordless_zebra_blinds.warranty_returns.tab_title' | t }}</div>
                        </div>
                        <div class="container mx-auto pt-6 pb-10">
                            {% if product_operation == 'motorized' %}
                                <div data-product-tab="0" class="transition-all hidden opacity-0">
                                    <div class="mt-0 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-childsafe', class: 'h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.motorized.0' | t }}</span>
                                    </div>
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-weave', class: 'h-8 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.motorized.1' | t }}</span>
                                    </div>
                                    {% comment %} <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-stain', class: 'h-12 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.motorized.2' | t }}</span>
                                    </div> {% endcomment %}
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-gears', class: 'ml-2 h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.motorized.3' | t }}</span>
                                    </div>
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-style', class: 'h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.motorized.4' | t }}</span>
                                    </div>
                                </div>
                            {% else %}
                                <div data-product-tab="0" class="transition-all hidden opacity-0">
                                    <div class="mt-0 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-childsafe', class: 'h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.non_motorized.0' | t }}</span>
                                    </div>
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-weave', class: 'h-8 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.non_motorized.1' | t }}</span>
                                    </div>
                                    {% comment %} <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-stain', class: 'h-12 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.non_motorized.2' | t }}</span>
                                    </div> {% endcomment %}
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-hand', class: 'h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.non_motorized.3' | t }}</span>
                                    </div>
                                    <div class="mt-4 py-4 flex gap-8 justify-start items-center bg-surface-200 rounded-md px-8">
                                        <div class="h-8 w-8 relative">
                                            <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 flex justify-center items-center">
                                                {% render 'icon-style', class: 'h-10 w-auto fill-content' %}
                                            </div>
                                        </div>
                                        <span class="font-medium">{{ 'products.product.cordless_zebra_blinds.highlights.non_motorized.4' | t }}</span>
                                    </div>
                                </div>
                            {% endif %}
                            <div data-product-tab="1" class="transition-all hidden opacity-0">
                                <div class="rz-h5">{{ 'products.product.cordless_zebra_blinds.materials_care.materials.title' | t }}</div>
                                <ul class="mt-4 ml-4 list-disc leading-8">
                                    <li>{{ 'products.product.cordless_zebra_blinds.materials_care.materials.0_html' | t }}</li>
                                    <li>{{ 'products.product.cordless_zebra_blinds.materials_care.materials.1_html' | t }}</li>
                                </ul>
                                <div class="mt-4 text-xl font-bold font-serif">{{ 'products.product.cordless_zebra_blinds.materials_care.care.title' | t }}</div>
                                <ul class="mt-4 ml-4 list-disc leading-8">
                                    <li>{{ 'products.product.cordless_zebra_blinds.materials_care.care.0' | t }}</li>
                                </ul>
                            </div>
                            <div data-product-tab="2" class="transition-all hidden opacity-0">
                                <div class="rz-h5">{{ 'products.product.cordless_zebra_blinds.warranty_returns.warranty.title' | t }}</div>
                                <div class="mt-4">{{ 'products.product.cordless_zebra_blinds.warranty_returns.warranty.0' | t }}</div>
                                <div class="mt-4">{{ 'products.product.cordless_zebra_blinds.warranty_returns.warranty.1' | t }}</div>
