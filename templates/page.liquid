<div data-no-overlay class="container mx-auto pt-12 pb-16">
    <div class="w-full lg:w-3/5 mx-auto">
        {% if page.handle == 'about-us' %}
            <div class="mb-8">
                {%- assign image = 'page-about-main.png' -%}
                <picture>
                    <source srcset="{{ image | asset_img_url: '1154x' }}" media="(min-width:1536px)" />
                    <source srcset="{{ image | asset_img_url: '1018x' }}" media="(min-width:1280px)" />
                    <source srcset="{{ image | asset_img_url: '868x' }}" media="(min-width:1024px)" />
                    <source srcset="{{ image | asset_img_url: '1152x' }}" media="(min-width:768px)" />
                    <source srcset="{{ image | asset_img_url: '896x' }}" media="(min-width:640px)" />
                    <source srcset="{{ image | asset_img_url: '768x' }}" media="(min-width:0px)" />
                    <img src="{{ image | asset_img_url: '768x' }}" alt="{{ image.alt }}" height="200" width="200" loading="lazy" class="w-full h-auto object-contain rounded-md" />
                </picture>
            </div>
        {% endif %}
        <h1 class="rz-h1">{{ page.title }}</h1>
        <div class="mt-8 text-lg space-y-4">{{ page.content }}</div>
        {% if page.handle == 'about-us' %}
            <div class="mt-24">
                <div class="rz-h2 text-center leading-relaxed w-11/12 lg:w-10/12 mx-auto">{{ 'templates.homepage.showcase_8.call_to_action_block.title' | t | newline_to_br }}</div>
                <a href="{{ routes['collections_url'] }}" class="block mt-12 mx-auto w-fit h-fit rz-btn-lg rz-btn-secondary" title="{{ 'templates.homepage.hero.button' | t }}">{{ 'templates.homepage.hero.button' | t }}</a>
            </div>
        {% endif %}
    </div>
</div>
