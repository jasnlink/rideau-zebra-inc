{% capture drawer_content %}
    <div class="flex flex-col h-full">
        <div class="shrink bg-surface-white">
            <div class="px-2 sm:px-8 flex justify-between items-center py-4 mx-auto">
                <span class="rz-h2 text-content">{{ 'templates.cart.your_cart' | t }}</span>
                <div role="button" data-drawer-close class="rz-icon-btn relative">
                    <div>{% render 'icon-close', class: 'h-5 w-auto fill-content-inverse text-content-inverse' %}</div>
                </div>
            </div>
        </div>
        <div data-cart-drawer-state="default" id="cart-drawer-content" class="h-full shrink overflow-auto flex flex-col"></div>
        <div data-cart-drawer-state="loading" class="hidden h-full items-center justify-center">
            <span>{% render 'icon-loading', class: 'animate-spin mx-auto h-12 w-12 text-content' %}</span>
        </div>
    </div>
{% endcapture %}
{% render 'component.drawer', drawer_id: 'cart-drawer', drawer_content: drawer_content %}
