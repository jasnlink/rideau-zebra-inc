                                <source srcset="{{ image | image_url: width: 1200 }}" media="(min-width:640px)" />
                                <source srcset="{{ image | image_url: width: 1200 }}" media="(min-width:0px)" />
                                <img src="{{ image | image_url: width: 1200 }}" alt="{{ image.alt }}" height="200" width="200" loading="lazy" class="w-full h-full object-cover rounded-md" />
                            </picture>
                        </div>
                        <div class="absolute top-0 left-0 right-0 bottom-0 bg-content opacity-40 rounded-md"></div>
                        <div class="relative my-12 mx-12 flex flex-col justify-between">
                            <div class="rz-h4 text-content-inverse">{{ article.title }}</div>
                            <div class="rz-btn-md rz-btn-ghost w-fit">{{ 'templates.homepage.showcase_12.read_button' | t }}</div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
        <div class="mt-4 w-full text-center">
            <a href="{{ blogs['news'].url }}" class="inline-block mt-8 rz-link text-xl">{{ 'templates.homepage.showcase_12.see_blog_button' | t }}</a>
        </div>
    </div>
</div>
<div class="bg-surface-100">
    <div class="container mx-auto mt-12 lg:mt-24 py-16 lg:py-32 text-center text-content">
        <div class="rz-h2">{{ 'templates.homepage.showcase_13.title' | t | newline_to_br }}</div>
        {% comment %} <a href="{{ shop.url }}" class="inline-block mt-8 text-lg lg:text-xl underline underline-offset-4">{{ 'templates.homepage.showcase_13.button' | t }}</a> {% endcomment %}
        <div class="mt-8 text-sm">{{ 'templates.homepage.showcase_13.sub' | t }}</div>
    </div>
</div>
