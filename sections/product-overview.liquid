{% if request.page_type == 'product' %}
    {% assign language = localization.language.iso_code %}
    <div class="py-20 bg-brand-50">
        <div class="container mx-auto">
            <div class="rz-h2 text-center">{{ 'templates.homepage.partners.title' | t }}</div>
            <div class="mt-12 grid grid-cols-2 lg:grid-cols-6 gap-4 lg:gap-2">
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-fadoq.svg' -%}
                    {% if language == 'fr' %}
                        {% assign partner_url = 'https://www.fadoq.ca/ile-de-montreal/rabais/habitation/rideau-zebra' %}
                    {% else %}
                        {% assign partner_url = 'https://www.fadoq.ca/en/ile-de-montreal/discounts/housing/827952-2' %}
                    {% endif %}
                    <a href="{{ partner_url }}" class="block" target="_blank">
                        <img src="{{ image | asset_url }}" alt="{{ 'FADOQ' }}" height="200" width="200" loading="lazy" class="w-full h-10 sm:h-16 object-contain" />
                    </a>
                </div>
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-fm1033.png' -%}
                    <img src="{{ image | asset_img_url: '240x' }}" alt="{{ 'FM103.3' }}" height="200" width="200" loading="lazy" class="w-full h-10 sm:h-16 object-contain" />
                </div>
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-courrier-v2.png' -%}
                    <a href="https://www.lecourrierdusud.ca/les-stores-alternes-un-equilibre-parfait-entre-style-et-fonctionnalite" class="block" target="_blank">
                        <img src="{{ image | asset_img_url: '240x' }}" alt="{{ 'Courrier du Sud' }}" height="200" width="200" loading="lazy" class="w-full h-12 sm:h-20 object-contain" />
                    </a>
                </div>
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-gravite-media.png' -%}
                    <img src="{{ image | asset_img_url: '240x' }}" alt="{{ 'Gravité Média' }}" height="200" width="200" loading="lazy" class="w-full h-10 sm:h-16 object-contain" />
                </div>
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-ma-vie-ma-region.png' -%}
                    <img src="{{ image | asset_img_url: '240x' }}" alt="{{ 'Ma Vie Ma Région' }}" height="200" width="200" loading="lazy" class="w-full h-10 sm:h-16 object-contain" />
                </div>
                <div class="col-span-1 flex items-center justify-center">
                    {%- assign image = 'partner-logo-walmart.png' -%}
                    <img src="{{ image | asset_img_url: '240x' }}" alt="{{ 'Walmart' }}" height="200" width="200" loading="lazy" class="w-full h-10 sm:h-16 object-contain" />
                </div>
            </div>
            <div class="mt-24">
                {% assign featured_article = articles['news/custom-zebra-blinds-installations-rideau-zebra-elevates-fm-103-3s-studios'] %}
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
                    <div class="overflow-hidden rounded-md">
                        <img
                            src="{{ featured_article.image | image_url: width: 900 }}"
                            srcset="{{ featured_article.image | image_url: width: 600 }} 600w, {{ featured_article.image | image_url: width: 900 }} 900w, {{ featured_article.image | image_url: width: 1200 }} 1200w"
                            sizes="(min-width: 1024px) 50vw, 100vw"
                            alt="{{ featured_article.title }}"
                            width="900" height="600"
                            loading="lazy"
                            class="w-full h-auto object-cover"
                        />
                    </div>
                    <div>
                        <span class="rz-overline text-content-secondary">{{ 'templates.homepage.featured_project.overline' | t }}</span>
                        <h3 class="mt-4 rz-h2">{{ 'templates.homepage.featured_project.title' | t }}</h3>
                        <p class="mt-6 text-content-secondary leading-relaxed">{{ 'templates.homepage.featured_project.description' | t }}</p>
                        <a href="{{ featured_article.url }}" class="inline-block mt-8 rz-btn-md rz-btn-secondary" title="{{ featured_article.title }}">{{ 'templates.homepage.featured_project.cta' | t }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
